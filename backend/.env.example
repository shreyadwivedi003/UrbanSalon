# ==============================================================================
# UrbanSalon Backend - Environment Configuration Blueprint (.env.example)
# Duplicate this file as '.env' and fill in your actual private operational keys.
# ==============================================================================

# Network Execution Configuration
PORT=8080
NODE_ENV=development

# Database Connection URI (PostgreSQL with pgvector enabled)
# Format: postgres://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgres://postgres:password@localhost:5432/urbansalon

# Cryptographic Session Signatures Secrets
# Generate strong random strings for local testing (e.g., using 'openssl rand -base64 32')
JWT_ACCESS_SECRET=your_local_development_access_token_secret_string_15_min
JWT_REFRESH_SECRET=your_local_development_refresh_token_secret_string_30_day

# Third-Party AI Engine SDK Access
# Get your API key from the Anthropic Developer Console
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-do-not-commit-real-keys